{
  "name": "react-19.2-features",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host --port 3000 --strictPort",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "lint-check": "tsc -b && eslint . --report-unused-disable-directives --max-warnings 0",
    "clean-packages": "rimraf node_modules package-lock.json",
    "clean-npm-cache": "npm cache clean --force",
    "audit-fix": "npm audit fix --force",
    "check-packages": "npx npm-check-updates -x typescript,eslint,@eslint/js ",
    "update-packages": "npx npm-check-updates -u -x typescript,eslint,@eslint/js ",
    "install-packages": "npm run update-packages && npm i"
  },
  "dependencies": {
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@mui/icons-material": "7.3.9",
    "@mui/material": "7.3.9",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@babel/core": "7.29.0",
    "@eslint/js": "9.39.4",
    "@rolldown/plugin-babel": "0.2.2",
    "@types/babel__core": "7.20.5",
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "babel-plugin-react-compiler": "1.0.0",
    "cross-env": "10.1.0",
    "eslint": "9.39.4",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "globals": "17.4.0",
    "npm-run-all": "4.1.5",
    "prettier": "npm:@btmills/prettier@3.3.3",
    "rimraf": "6.1.3",
    "typescript": "5.9.3",
    "typescript-eslint": "8.57.2",
    "vite": "8.0.3",
    "vite-plugin-babel": "1.6.0"
  },
  "prettier": {
    "printWidth": 120
  }
}
